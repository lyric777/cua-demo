# Anthropic API key — required for Claude
ANTHROPIC_API_KEY=your_anthropic_api_key

# Optional: override the Anthropic API base URL (e.g. for compatible providers like Packy)
# When set, x-api-key header is automatically converted to Authorization: Bearer
# ANTHROPIC_BASE_URL=https://www.packyapi.com

# e2b API key — required for desktop sandboxes (https://e2b.dev)
E2B_API_KEY=your_e2b_api_key

# Optional: HTTP/HTTPS proxy for outbound requests (e.g. corporate networks)
# HTTPS_PROXY=http://proxy.example.com:8080
